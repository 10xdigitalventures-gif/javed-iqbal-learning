{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production"
      }
    },
    "tenant-template": {
      "distribution": "internal",
      "android": {
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_APP_NAME": "My Expert App",
        "EXPO_PUBLIC_APP_SLUG": "my-expert-app",
        "EXPO_PUBLIC_BUNDLE_ID": "com.example.myexpertapp",
        "EXPO_PUBLIC_ANDROID_PKG": "com.example.myexpertapp",
        "EXPO_PUBLIC_API_URL": "https://api.mentoringhub.online/api",
        "EXPO_PUBLIC_TENANT_SLUG": "my-expert-slug",
        "EXPO_PUBLIC_BRAND_COLOR": "#FF9100",
        "EAS_PROJECT_ID": "YOUR-EAS-PROJECT-ID"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}