# ─────────────────────────────────────────────────────────────
# Mobile white-label build env vars
# Copy to .env (local dev) or set in EAS Build profile secrets
# ─────────────────────────────────────────────────────────────

# App display name (appears in launcher + notifications)
EXPO_PUBLIC_APP_NAME=Prof. Dr. Javed Iqbal

# Expo slug (must match your eas.json build profile)
EXPO_PUBLIC_APP_SLUG=javed-iqbal-learning

# iOS bundle identifier
EXPO_PUBLIC_BUNDLE_ID=com.javediqbal.learning

# Android package name
EXPO_PUBLIC_ANDROID_PKG=com.javediqbal.learning

# Backend API URL
EXPO_PUBLIC_API_URL=https://api.10xdigitalventures.com/api

# Tenant slug — leave empty for default (Dr. Javed Iqbal) build
# Set to the tenant's slug for a white-label tenant build
EXPO_PUBLIC_TENANT_SLUG=

# Primary brand color (hex)
EXPO_PUBLIC_BRAND_COLOR=#FF9100

# EAS project ID (from expo.dev)
EAS_PROJECT_ID=431ff4dd-dc8b-43af-8544-511099762aaa
