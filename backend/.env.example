# Server
PORT=4000
NODE_ENV=development

# Public URLs
# IMPORTANT: In production set PUBLIC_API_URL to your REAL public API base
# (same value as the frontend NEXT_PUBLIC_API_URL), e.g.
# https://app.yourdomain.com/api  -- the backend signs all media/receipt/image
# URLs with this host. If left as localhost, every image will be broken.
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000/api
# Production example:
#   PUBLIC_WEB_URL=https://app.10xdigitalventures.com
#   PUBLIC_API_URL=https://api.10xdigitalventures.com/api
# Extra CORS origins (comma-separated) for tenant custom domains + marketplace.
# Subdomains of PLATFORM_ROOT_DOMAIN are allowed automatically in production.
CORS_ALLOWED_ORIGINS=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consult_hub?schema=public

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# File uploads & object storage
UPLOAD_DIR=./uploads
# Signed media URLs
MEDIA_SIGNING_SECRET=change-me-too
MEDIA_URL_EXPIRES_SEC=604800
# Storage driver: "local" (default) or "s3" (S3/R2/B2/MinIO)
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set S3_ENDPOINT for R2/MinIO; leave blank for AWS S3
S3_ENDPOINT=
# Optional: public CDN base URL for objects; leave blank to use presigned URLs
S3_PUBLIC_URL=
# Force path-style addressing (auto-on when S3_ENDPOINT is set). Set "true" for MinIO
S3_FORCE_PATH_STYLE=

# Rate limiting (global)
RATE_LIMIT_TTL_SEC=60
RATE_LIMIT_MAX=120

# Email (SMTP). Leave blank to log emails to console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS + WhatsApp via Twilio. Leave blank to log messages to console (mock mode).
# Per-user notification preferences decide which of these channels actually fire.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
# Country code (no +) used for phone numbers stored without one. Default: 92 (PK).
DEFAULT_PHONE_COUNTRY_CODE=92

# ---- Subscriptions: multi-currency display + dunning ----
# Units of each currency per 1 PKR (display only; charges stay in plan currency).
EXCHANGE_RATES_PKR={"USD":0.0036,"GBP":0.0028,"EUR":0.0033,"SAR":0.0135,"AED":0.0132}
# Days before expiry to start sending renewal reminders.
SUB_RENEW_REMINDER_DAYS=3
# Grace days after expiry during which access continues while payment is retried.
SUB_GRACE_DAYS=7
# Max renewal reminder attempts before the subscription is expired.
SUB_MAX_RENEW_ATTEMPTS=4
MAIL_FROM="Consult Hub <no-reply@consulthub.app>"

# Payments
# Comma-separated list of active gateways the client may choose from at checkout.
# Supported: gopayfast, whop. If none are configured/enabled, the built-in dev
# mock checkout is used automatically.
PAYMENT_PROVIDERS=gopayfast,whop

# GoPayFast (https://gopayfast.com) = the Pakistani PayFast gateway.
#
# GOPAYFAST_MODE picks which environment is live:
#   sandbox -> IPG base https://ipguat.apps.net.pk/Ecommerce/api/Transaction
#   live    -> IPG base https://ipg1.apps.net.pk/Ecommerce/api/Transaction
#
# You can keep BOTH sandbox and live credentials configured at the same time and
# just flip GOPAYFAST_MODE between them. The mode-specific keys below take
# priority; if a mode-specific key is blank it falls back to the generic
# GOPAYFAST_MERCHANT_ID / GOPAYFAST_SECURED_KEY pair.
GOPAYFAST_MODE=sandbox            # sandbox | live

# Generic fallback credentials (used when the mode-specific keys are blank).
GOPAYFAST_MERCHANT_ID=
GOPAYFAST_SECURED_KEY=

# Sandbox (UAT) credentials from your GoPayFast sandbox merchant panel.
GOPAYFAST_SANDBOX_MERCHANT_ID=
GOPAYFAST_SANDBOX_SECURED_KEY=

# Live (production) credentials from your GoPayFast live merchant panel.
GOPAYFAST_LIVE_MERCHANT_ID=
GOPAYFAST_LIVE_SECURED_KEY=

# Optional: override the IPG base URL (otherwise derived from GOPAYFAST_MODE).
# GOPAYFAST_API_BASE=
# Optional: name shown on the hosted checkout.
# GOPAYFAST_MERCHANT_NAME=Consult Hub

# Whop (https://whop.com).
WHOP_API_KEY=
WHOP_COMPANY_ID=
WHOP_WEBHOOK_SECRET=
# Optional: override the Whop API base URL.
# WHOP_API_BASE=https://api.whop.com

# ---------------------------------------------------------------------------
# Learning platform (Prof. Dr. Javed Iqbal Learning App) - Phase 1
# ---------------------------------------------------------------------------

# Pakistani PayFast gateway.
# NOTE: "GoPayFast" (gopayfast.com) IS the Pakistani PayFast gateway and is
# already wired above via PAYMENT_PROVIDERS=gopayfast and the GOPAYFAST_* keys.
# The PayFast credential names from the product brief map as follows:
#   PayFast "Company / Merchant ID" -> GOPAYFAST_MERCHANT_ID
#   PayFast "API Key / Secured Key" -> GOPAYFAST_SECURED_KEY
#   PayFast "Webhook Secret"        -> GOPAYFAST_WEBHOOK_SECRET (optional; used
#                                      to verify the IPN/webhook signature)
# Leave the keys blank in development to fall back to the built-in mock checkout.
GOPAYFAST_WEBHOOK_SECRET=

# Secure offline content encryption.
# Server-side key used to encrypt protected book content per user before it is
# delivered to the app (AES-256-GCM). Must be a 32-byte value (hex or base64).
# NEVER hardcode this - generate per environment, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTENT_ENCRYPTION_KEY=

# ===========================================================================
# STORAGE ABSTRACTION (Scalable Cloud Storage)
# ===========================================================================
# Storage provider to use: "supabase", "bunny", "r2", or "s3"
# Active cloud storage driver: supabase | bunny | r2 | s3
# For AWS S3 set this to "s3" and fill the S3_* vars above.
STORAGE_PROVIDER=supabase

# 1. Supabase Storage (Current Development)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=consult-hub-storage

# 2. Bunny Storage + CDN (Future Production)
BUNNY_STORAGE_KEY=
BUNNY_ZONE_ID=
BUNNY_REGION=
BUNNY_PULL_ZONE_URL=

# 3. Cloudflare R2 / S3 (Future Production)
CLOUDFLARE_R2_KEY=
CLOUDFLARE_R2_SECRET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# Hawwa AI reader companion (OpenAI-compatible Chat Completions)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Calendar / Meet auto-link (optional)
# GOOGLE_SA_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_SA_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
# GOOGLE_CALENDAR_DELEGATE=consultant@yourdomain.com

# Multi-tenant / marketplace onboarding
PLATFORM_ROOT_DOMAIN=10xdigitalventures.com

# LeadConnector (GoHighLevel) OAuth app + MCP
# These are normally set in Admin > Settings (stored in DB, mirrored to env).
LEADCONNECTOR_CLIENT_ID=
LEADCONNECTOR_CLIENT_SECRET=
LEADCONNECTOR_MCP_URL=https://services.leadconnectorhq.com/mcp/
LEADCONNECTOR_MCP_TOKEN=

# GHL outbound event sync (marketing engine bridge)
# Off by default; turn on once LeadConnector is connected.
GHL_SYNC_ENABLED=false
GHL_INACTIVE_DAYS=30
# Daily cron for the inactive-contact sweep (in-process, no external scheduler).
# Follows GHL_SYNC_ENABLED unless overridden here ("true"/"false").
GHL_CRON_ENABLED=
# Hour of day (0-23, server local time) to run the sweep. Default 3 (03:00).
GHL_CRON_HOUR=3

# Referral program reward points (Phase 2). Points granted on a referred
# buyer's purchase: to the referrer and (welcome) to the buyer.
REFERRAL_REWARD_POINTS=100
REFERRAL_WELCOME_POINTS=50

# Platform identity (white-label)
PLATFORM_NAME=10X Platform
# CNAME target for custom-domain setup. Tenants point their vanity domain here.
PLATFORM_CNAME_TARGET=cname.10xdigitalventures.com

# Horizontal scaling: Redis (optional for single-instance)
# Set REDIS_URL to enable Redis-backed rate limiting across multiple API instances.
# Leave blank to use in-process defaults (single instance only).
REDIS_URL=
