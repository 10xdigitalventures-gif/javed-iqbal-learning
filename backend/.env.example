# Server
PORT=4000
NODE_ENV=development

# Public URLs
# IMPORTANT: In production set PUBLIC_API_URL to your REAL public API base
# (same value as the frontend NEXT_PUBLIC_API_URL), e.g.
# https://app.yourdomain.com/api  -- the backend signs all media/receipt/image
# URLs with this host. If left as localhost, every image will be broken.
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consult_hub?schema=public

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# File uploads & object storage
UPLOAD_DIR=./uploads
# Signed media URLs
MEDIA_SIGNING_SECRET=change-me-too
MEDIA_URL_EXPIRES_SEC=604800
# Storage driver: "local" (default) or "s3" (S3/R2/B2/MinIO)
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set S3_ENDPOINT for R2/MinIO; leave blank for AWS S3
S3_ENDPOINT=

# Rate limiting (global)
RATE_LIMIT_TTL_SEC=60
RATE_LIMIT_MAX=120

# Email (SMTP). Leave blank to log emails to console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS + WhatsApp via Twilio. Leave blank to log messages to console (mock mode).
# Per-user notification preferences decide which of these channels actually fire.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
# Country code (no +) used for phone numbers stored without one. Default: 92 (PK).
DEFAULT_PHONE_COUNTRY_CODE=92

# ---- Subscriptions: multi-currency display + dunning ----
# Units of each currency per 1 PKR (display only; charges stay in plan currency).
EXCHANGE_RATES_PKR={"USD":0.0036,"GBP":0.0028,"EUR":0.0033,"SAR":0.0135,"AED":0.0132}
# Days before expiry to start sending renewal reminders.
SUB_RENEW_REMINDER_DAYS=3
# Grace days after expiry during which access continues while payment is retried.
SUB_GRACE_DAYS=7
# Max renewal reminder attempts before the subscription is expired.
SUB_MAX_RENEW_ATTEMPTS=4
MAIL_FROM="Consult Hub <no-reply@consulthub.app>"

# Payments
# Comma-separated list of active gateways the client may choose from at checkout.
# Supported: gopayfast, whop. If none are configured/enabled, the built-in dev
# mock checkout is used automatically.
PAYMENT_PROVIDERS=gopayfast,whop

# GoPayFast (https://gopayfast.com). Leave keys blank to fall back to the mock.
GOPAYFAST_MERCHANT_ID=
GOPAYFAST_SECURED_KEY=
GOPAYFAST_MODE=sandbox            # sandbox | live
# Optional: override the IPG base URL (otherwise derived from GOPAYFAST_MODE).
# GOPAYFAST_API_BASE=
# Optional: name shown on the hosted checkout.
# GOPAYFAST_MERCHANT_NAME=Consult Hub

# Whop (https://whop.com).
WHOP_API_KEY=
WHOP_COMPANY_ID=
WHOP_WEBHOOK_SECRET=
# Optional: override the Whop API base URL.
# WHOP_API_BASE=https://api.whop.com

# ---------------------------------------------------------------------------
# Learning platform (Prof. Dr. Javed Iqbal Learning App) - Phase 1
# ---------------------------------------------------------------------------

# Pakistani PayFast gateway.
# NOTE: "GoPayFast" (gopayfast.com) IS the Pakistani PayFast gateway and is
# already wired above via PAYMENT_PROVIDERS=gopayfast and the GOPAYFAST_* keys.
# The PayFast credential names from the product brief map as follows:
#   PayFast "Company / Merchant ID" -> GOPAYFAST_MERCHANT_ID
#   PayFast "API Key / Secured Key" -> GOPAYFAST_SECURED_KEY
#   PayFast "Webhook Secret"        -> GOPAYFAST_WEBHOOK_SECRET (optional; used
#                                      to verify the IPN/webhook signature)
# Leave the keys blank in development to fall back to the built-in mock checkout.
GOPAYFAST_WEBHOOK_SECRET=

# Secure offline content encryption.
# Server-side key used to encrypt protected book content per user before it is
# delivered to the app (AES-256-GCM). Must be a 32-byte value (hex or base64).
# NEVER hardcode this - generate per environment, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTENT_ENCRYPTION_KEY=

# ===========================================================================
# STORAGE ABSTRACTION (Scalable Cloud Storage)
# ===========================================================================
# Storage provider to use: "supabase", "bunny", "r2", or "s3"
STORAGE_PROVIDER=supabase

# 1. Supabase Storage (Current Development)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=consult-hub-storage

# 2. Bunny Storage + CDN (Future Production)
BUNNY_STORAGE_KEY=
BUNNY_ZONE_ID=
BUNNY_REGION=
BUNNY_PULL_ZONE_URL=

# 3. Cloudflare R2 / S3 (Future Production)
CLOUDFLARE_R2_KEY=
CLOUDFLARE_R2_SECRET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# Hawwa AI reader companion (OpenAI-compatible Chat Completions)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
