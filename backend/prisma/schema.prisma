// Consultant & Mentorship Platform — Prisma schema
// Postgres. Run: npx prisma generate && npx prisma migrate dev && npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CONSULTANT
  CLIENT
}

enum PackageType {
  ONE_TIME
  MONTHLY
  ANNUAL
  CUSTOM
}

// Communication channel a plan unlocks. COMBINED unlocks text + audio + video.
enum PackageChannel {
  TEXT
  AUDIO
  VIDEO
  COMBINED
}

enum PurchaseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum MessageType {
  TEXT
  AUDIO
  VIDEO
  IMAGE
  FILE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum MeetingStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentKind {
  ONE_TIME
  SUBSCRIPTION
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(CLIENT)
  isActive  Boolean  @default(true)
  avatarUrl String?

  // consultant-only profile fields
  bio        String?
  expertise  String?
  title      String?

  // Expo push token for mobile notifications (null when not registered)
  pushToken  String?

  // Concurrent device limit: how many devices may stay logged in at once.
  // When a new device logs in beyond this limit, the oldest device is signed
  // out (Netflix/YouTube style). Admin-configurable per user.
  maxDevices Int      @default(2)
  devices    UserDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  clientConversations     Conversation[] @relation("ClientConversations")
  consultantConversations Conversation[] @relation("ConsultantConversations")
  sentMessages            Message[]      @relation("SentMessages")
  messageReactions        MessageReaction[] @relation("UserReactions")
  clientPurchases         Purchase[]     @relation("ClientPurchases")
  consultantPurchases     Purchase[]     @relation("ConsultantPurchases")
  availability            Availability[]
  clientMeetings          Meeting[]      @relation("ClientMeetings")
  consultantMeetings      Meeting[]      @relation("ConsultantMeetings")
  payments                Payment[]
  notifications           Notification[]
  communityMemberships    CommunityMember[]
  notificationPreference  NotificationPreference?
  communityPosts          CommunityPost[]
  communityComments       CommunityComment[]
  communityPostLikes      CommunityPostLike[]
  activityLogs            ActivityLog[]

  // Learning / library relations (Phase 1: books)
  entitlements          Entitlement[]
  readingProgress       ReadingProgress[]
  bookmarks             Bookmark[]
  highlights            Highlight[]
  readerNotes           ReaderNote[]
  offlineContents       OfflineContent[]
  lessonCompletions     LessonCompletion[]
  orders                Order[]
  subscriptions         Subscription[]
  hardCopyOrders        HardCopyOrder[]

  // Future course system relations (scaffolded)
  enrollments           Enrollment[]
  quizAttempts          QuizAttempt[]
  assignmentSubmissions AssignmentSubmission[]
  certificates          Certificate[]

  // Engagement (Phase 8): reviews, lesson notes, Q&A
  courseReviews         CourseReview[]
  lessonNotes           LessonNote[]
  lessonQuestions       LessonQuestion[]
  lessonAnswers         LessonAnswer[]

  // Gamification (Phase 10): points, streaks, badges
  gameStat              UserGameStat?
  badges                UserBadge[]
  courseComments        CourseComment[]

  // Plans explicitly assigned to this consultant (many-to-many). Global plans
  // (Package.isGlobal = true) are available to every consultant and are not
  // listed here.
  packages                Package[]      @relation("PackageConsultants")
}

model Package {
  id          String      @id @default(cuid())
  name        String
  description String?
  type        PackageType    @default(ONE_TIME)
  channel     PackageChannel @default(COMBINED)
  price       Float          @default(0)
  currency    String         @default("PKR")
  isActive    Boolean        @default(true)

  // When true the plan is offered by every consultant. When false it is only
  // offered by the consultants in the `consultants` relation below.
  isGlobal    Boolean        @default(false)

  // configurable limits (null = unlimited / not applicable)
  textLimit         Int? // number of text messages allowed
  audioLimit        Int? // number of audio messages allowed
  videoLimit        Int? // number of video messages allowed
  sessionLimit      Int? // number of live meeting sessions
  sessionDuration   Int? // minutes per meeting session
  audioDuration     Int? // max seconds per audio message
  videoDuration     Int? // max seconds per video message
  responseAllowance Int? // consultant responses included

  // billing period in days for recurring packages (e.g. 30, 365). null for one-time
  billingDays Int?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  // Consultants this plan is assigned to (ignored when isGlobal = true).
  consultants User[]   @relation("PackageConsultants")
}

model Purchase {
  id           String         @id @default(cuid())
  clientId     String
  consultantId String?
  packageId    String
  status       PurchaseStatus @default(PENDING)
  autoRenew    Boolean        @default(false)

  // snapshot of limits at purchase time
  textLimit       Int?
  audioLimit      Int?
  videoLimit      Int?
  sessionLimit    Int?
  sessionDuration Int?
  audioDuration   Int?
  videoDuration   Int?

  // usage counters
  textUsed     Int @default(0)
  audioUsed    Int @default(0)
  videoUsed    Int @default(0)
  sessionsUsed Int @default(0)

  startedAt DateTime  @default(now())
  expiresAt DateTime?

  client     User    @relation("ClientPurchases", fields: [clientId], references: [id])
  consultant User?   @relation("ConsultantPurchases", fields: [consultantId], references: [id])
  package    Package @relation(fields: [packageId], references: [id])
  messages   Message[]
  meetings   Meeting[]
  payments   Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id           String   @id @default(cuid())
  clientId     String
  consultantId String
  lastMessageAt DateTime @default(now())
  createdAt    DateTime @default(now())

  client     User      @relation("ClientConversations", fields: [clientId], references: [id])
  consultant User      @relation("ConsultantConversations", fields: [consultantId], references: [id])
  messages   Message[]

  @@unique([clientId, consultantId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  purchaseId     String?
  type           MessageType   @default(TEXT)
  body           String?
  mediaUrl       String?
  fileName       String?
  durationSec    Int?
  status         MessageStatus @default(SENT)
  replyToId      String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id])
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")
  reactions    MessageReaction[]
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("UserReactions", fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model Availability {
  id           String  @id @default(cuid())
  consultantId String
  weekday      Int // 0=Sunday .. 6=Saturday
  startTime    String // "09:00"
  endTime      String // "17:00"
  isActive     Boolean @default(true)

  consultant User @relation(fields: [consultantId], references: [id])
}

model Meeting {
  id           String        @id @default(cuid())
  clientId     String
  consultantId String
  purchaseId   String?
  title        String
  scheduledAt  DateTime
  durationMin  Int           @default(30)
  status       MeetingStatus @default(REQUESTED)
  meetingUrl   String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  client     User      @relation("ClientMeetings", fields: [clientId], references: [id])
  consultant User      @relation("ConsultantMeetings", fields: [consultantId], references: [id])
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  purchaseId String?
  amount     Float
  currency   String        @default("PKR")
  gateway    String        @default("mock")
  kind       PaymentKind   @default(ONE_TIME)
  status     PaymentStatus @default(PENDING)
  reference  String?
  invoiceNo  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Commerce order this payment settles (books, bundles, subscriptions). The
  // legacy consultation flow uses `purchaseId` instead; exactly one is set.
  orderId    String?

  // Manual bank-transfer fields (gateway = "bank_transfer"). Set when a buyer
  // submits proof of an offline transfer; an admin verifies to mark it paid.
  proofKey   String?
  senderName String?
  senderRef  String?
  manualNote String?

  user     User      @relation(fields: [userId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel @default(IN_APP)
  type      String
  title     String
  body      String?
  read      Boolean             @default(false)
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])
}

// Per-user delivery preferences for notifications. One row per user; created
// lazily with sensible defaults the first time it is read or updated.
model NotificationPreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  inApp      Boolean  @default(true)
  email      Boolean  @default(true)
  sms        Boolean  @default(false)
  whatsapp   Boolean  @default(false)
  push       Boolean  @default(true)
  // Notification "type" values the user has muted across every channel.
  mutedTypes String[] @default([])
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPaid      Boolean  @default(false)
  price       Float    @default(0)
  currency    String   @default("PKR")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  members CommunityMember[]
  posts   CommunityPost[]
  orders  Order[]
}

model CommunityMember {
  id          String   @id @default(cuid())
  communityId String
  userId      String
  isModerator Boolean  @default(false)
  joinedAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId])
}

model CommunityPost {
  id          String   @id @default(cuid())
  communityId String
  authorId    String
  body        String
  mediaUrl    String?
  createdAt   DateTime @default(now())

  community Community          @relation(fields: [communityId], references: [id])
  author    User               @relation(fields: [authorId], references: [id])
  comments  CommunityComment[]
  likes     CommunityPostLike[]
  isAnnouncement Boolean        @default(false)
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   CommunityPost @relation(fields: [postId], references: [id])
  author User          @relation(fields: [authorId], references: [id])
}

model OtpCode {
  id        String     @id @default(cuid())
  email     String
  code      String
  purpose   OtpPurpose @default(LOGIN)
  expiresAt DateTime
  used      Boolean    @default(false)
  createdAt DateTime   @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  meta      String?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt
}

// ============================================================================
// LEARNING PLATFORM — Phase 1 (Books / Library / Subscriptions / Orders)
// Future-ready scaffolding for Courses, Lessons, Quizzes, Assignments below.
// ============================================================================

enum LearningProductKind {
  BOOK
  BUNDLE
  SUBSCRIPTION
  COURSE
  COMMUNITY
}

// How a piece of content is accessed once owned.
enum AccessType {
  LIFETIME // one-time purchase, never expires
  SUBSCRIPTION // available only while a subscription is active
}

enum EntitlementSource {
  PURCHASE
  BUNDLE
  SUBSCRIPTION
  ADMIN_GRANT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum SubscriptionInterval {
  MONTHLY
  SIX_MONTHS
  YEARLY
  LIFETIME
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum HardCopyOrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum LessonType {
  VIDEO
  PDF
  TEXT
  QUIZ
  ASSIGNMENT
}

enum SubmissionStatus {
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum LessonSource {
  UPLOAD
  LINK
  MEDIA
}

// A reusable media item in the Media Library. Every upload is recorded here so
// it can be listed, previewed, shared, deleted, and re-used across courses,
// lessons, communities and messages.
model MediaAsset {
  id          String   @id @default(cuid())
  ownerId     String
  // Storage object key (cloud) or local filename used to (re)sign URLs.
  key         String
  // image | video | audio | pdf | file
  type        String
  filename    String
  mimeType    String
  size        Int      @default(0)
  durationSec Int?
  // cloud | local — which delivery path produced this asset's key.
  storage     String   @default("cloud")
  createdAt   DateTime @default(now())

  @@index([ownerId])
  @@index([type])
}

model BookCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  books Book[]
}

model Book {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  author      String  @default("Prof. Dr. Javed Iqbal")
  description String?
  coverUrl    String?
  language    String  @default("en")
  // Optional secondary-language (Urdu) edition fields so a single book can
  // hold both an English and an Urdu version in one record. The reader shows a
  // language toggle when any Urdu content is present.
  titleUrdu       String?
  descriptionUrdu String?
  pageCount   Int?
  categoryId  String?

  // Pricing. Digital price is the in-app price; hardCopyPrice is for physical orders.
  price         Float   @default(0)
  currency      String  @default("PKR")
  hardCopyPrice Float?
  allowHardCopy Boolean @default(false)

  // LIFETIME = unlocked by a one-time purchase; SUBSCRIPTION = unlocked by an
  // active subscription. Admin-configurable per book.
  accessType AccessType @default(LIFETIME)

  isFeatured  Boolean @default(false)
  isPublished Boolean @default(true)

  // Encrypted content references. `contentKey` points to the protected (server
  // side) source used to issue a per-user encrypted copy. `previewContentKey`
  // is a short, freely viewable sample. Raw files are never exposed directly.
  contentKey        String?
  previewContentKey String?
  // Urdu edition of the full single-file content (parallel to contentKey).
  contentKeyUrdu    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category        BookCategory?     @relation(fields: [categoryId], references: [id])
  chapters        Chapter[]
  bundleItems     BundleItem[]
  entitlements    Entitlement[]
  offlineContents OfflineContent[]
  readingProgress ReadingProgress[]
  bookmarks       Bookmark[]
  highlights      Highlight[]
  readerNotes     ReaderNote[]
  orders          Order[]
  hardCopyOrders  HardCopyOrder[]
}

model Chapter {
  id         String  @id @default(cuid())
  bookId     String
  index      Int
  title      String
  titleUrdu  String?
  // Encrypted/protected content reference for this chapter.
  contentKey     String?
  // Urdu edition of this chapter's content (parallel to contentKey).
  contentKeyUrdu String?
  // Free preview/lecture: readable without purchasing the book. Lets admins
  // hand-pick which chapters are shown for free.
  isFree     Boolean @default(false)
  pageStart  Int?
  pageEnd    Int?

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]
  highlights Highlight[]
  readerNotes ReaderNote[]

  @@unique([bookId, index])
}

model Bundle {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  coverUrl    String?
  price       Float   @default(0)
  currency    String  @default("PKR")
  isFeatured  Boolean @default(false)
  isPublished Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items  BundleItem[]
  orders Order[]
}

model BundleItem {
  id       String @id @default(cuid())
  bundleId String
  bookId   String

  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bundleId, bookId])
}

// A commerce order for a digital product (book, bundle or subscription plan).
// Settled by one or more Payment rows; on success it is fulfilled into
// Entitlement / Subscription records.
model Order {
  id       String              @id @default(cuid())
  userId   String
  kind     LearningProductKind
  status   OrderStatus         @default(PENDING)
  amount   Float
  currency String              @default("PKR")
  // Coupon applied at checkout (global coupons). discount is in currency units.
  couponCode String?
  discount   Float   @default(0)
  // Optional course access offer/tier this order was purchased through.
  offerId    String?

  bookId   String?
  bundleId String?
  planId   String?
  courseId String?
  communityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id])
  book     Book?            @relation(fields: [bookId], references: [id])
  bundle   Bundle?          @relation(fields: [bundleId], references: [id])
  plan     SubscriptionPlan? @relation(fields: [planId], references: [id])
  course   Course?          @relation(fields: [courseId], references: [id])
  community Community?       @relation(fields: [communityId], references: [id])
  payments Payment[]
}

// "My Books": a user's access grant to a single book. expiresAt is null for
// lifetime access; set for subscription-derived access.
model Entitlement {
  id        String            @id @default(cuid())
  userId    String
  bookId    String
  source    EntitlementSource @default(PURCHASE)
  isActive  Boolean           @default(true)
  grantedAt DateTime          @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

// Tracks a securely downloaded, encrypted offline copy on a user's device. The
// raw content never leaves app storage; we persist only metadata + a wrapped
// key reference so the same copy can be re-issued / revoked.
model OfflineContent {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  // Opaque reference to the per-user wrapped content key (KMS/keystore handle).
  wrappedKeyRef String?
  version      Int      @default(1)
  sizeBytes    Int?
  downloadedAt DateTime @default(now())
  lastSyncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model ReadingProgress {
  id                String   @id @default(cuid())
  userId            String
  bookId            String
  lastChapterIndex  Int      @default(0)
  lastPage          Int      @default(0)
  percentComplete   Float    @default(0)
  chaptersCompleted Int      @default(0)
  readingSeconds    Int      @default(0)
  // Audiobook listening position: last chapter played + offset within it (sec).
  lastAudioChapterId String?
  audioPositionSec   Int     @default(0)
  audioDurationSec   Int?
  isCompleted       Boolean  @default(false)
  lastReadAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  chapterId  String?
  page       Int
  label      String?
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  book    Book     @relation(fields: [bookId], references: [id])
  chapter Chapter? @relation(fields: [chapterId], references: [id])
}

model Highlight {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  chapterId String?
  page      Int
  text      String
  color     String   @default("#FF7A1A")
  position  String? // JSON-encoded selection range
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  book    Book     @relation(fields: [bookId], references: [id])
  chapter Chapter? @relation(fields: [chapterId], references: [id])
}

model ReaderNote {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  chapterId String?
  page      Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  book    Book     @relation(fields: [bookId], references: [id])
  chapter Chapter? @relation(fields: [chapterId], references: [id])
}

model SubscriptionPlan {
  id          String               @id @default(cuid())
  name        String
  description String?
  interval    SubscriptionInterval @default(MONTHLY)
  // Access duration in days. Null = lifetime (admin-configurable).
  durationDays Int?
  price       Float                @default(0)
  currency    String               @default("PKR")
  isActive    Boolean              @default(true)
  features    String? // JSON-encoded list of feature strings
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  subscriptions Subscription[]
  orders        Order[]
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(PENDING)
  autoRenew Boolean            @default(false)
  startedAt DateTime           @default(now())
  expiresAt DateTime? // null = lifetime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  // Dunning / retry state for auto-renewing subscriptions.
  renewAttempts  Int       @default(0)
  lastReminderAt DateTime?
  graceUntil     DateTime? // access continues until this date while payment is retried
  pendingOrderId String? // the open renewal order awaiting payment

  user User             @relation(fields: [userId], references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
}

model HardCopyOrder {
  id        String              @id @default(cuid())
  userId    String
  bookId    String?
  name      String
  phone     String
  address   String
  city      String
  quantity  Int                 @default(1)
  status    HardCopyOrderStatus @default(PENDING)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User  @relation(fields: [userId], references: [id])
  book Book? @relation(fields: [bookId], references: [id])
}

model CommunityPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

// ============================================================================
// FUTURE COURSE SYSTEM (scaffolded — not wired into controllers yet)
// ============================================================================

// Unlock rule for a module or lesson:
//   SINGLE = unlock as soon as the previous item is completed by the learner.
//   BOTH   = previous item completed AND a time delay has elapsed since then.
enum UnlockPolicy {
  OPEN
  SEQUENTIAL
  DRIP
}

enum ModuleLockMode {
  SINGLE
  BOTH
}

// A section/chapter grouping lessons inside a course. Modules unlock in order;
// a module can additionally be time-gated ("drip") so it only opens N hours
// after the previous module was completed by that learner.
model CourseModule {
  id               String         @id @default(cuid())
  courseId         String
  title            String
  index            Int
  lockMode         ModuleLockMode @default(SINGLE)
  // Hours to wait after the previous module is completed before this one opens.
  // Only enforced when lockMode = BOTH.
  unlockDelayHours Int            @default(0)
  // Draft vs Published. Draft modules are hidden from learners.
  isPublished      Boolean        @default(true)
  // Optional parent module id. When set this module is a SUB-MODULE nested
  // under another module. null = top-level module.
  parentId         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent   CourseModule?  @relation("ModuleTree", fields: [parentId], references: [id], onDelete: Cascade)
  children CourseModule[] @relation("ModuleTree")
  lessons  Lesson[]

  @@unique([courseId, index])
  @@index([parentId])
}

model Course {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  coverUrl    String?
  price       Float   @default(0)
  currency    String  @default("PKR")
  isPublished Boolean @default(false)
  // Default access duration (days) granted on enrollment/purchase.
  // null = lifetime access.
  accessDurationDays Int?
  // How lessons unlock after purchase:
  //   OPEN       = everything unlocked immediately
  //   SEQUENTIAL = one-by-one (complete previous to open next) [default]
  //   DRIP       = sequential + time delays (per-module/lesson lockMode = BOTH)
  unlockPolicy UnlockPolicy @default(SEQUENTIAL)
  // YouTube-style offline re-validation window (days). A downloaded video must
  // reconnect to the server within this window or it stops playing until the
  // device is online again.
  offlineValidityDays Int @default(30)
  // Course tags (filter/discovery)
  tags                String[] @default([])
  // Instructor details (shown on course detail + checkout)
  instructorHeading   String?
  instructorName      String?
  instructorTitle     String?
  instructorBio       String?
  instructorAvatarUrl String?
  // Learning experience
  autoplayNext        Boolean  @default(true)
  autoplayFirst       Boolean  @default(false)
  autoComplete        Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
  modules     CourseModule[]
  enrollments Enrollment[]
  quizzes     Quiz[]
  assignments Assignment[]
  certificates Certificate[]
  orders      Order[]
  reviews     CourseReview[]
  offers       CourseOffer[]
  comments     CourseComment[]
  badges       CourseBadge[]
  liveSessions LiveSession[]
}

model Lesson {
  id         String     @id @default(cuid())
  courseId   String
  index      Int
  title      String
  type       LessonType @default(VIDEO)
  // Protected/encrypted streaming or document reference. Never a direct download URL.
  contentKey String?
  // External streaming/embed URL (YouTube, Vimeo, or direct file) used when source = LINK.
  videoUrl     String?
  // Optional per-lesson thumbnail/poster image (URL or storage key).
  thumbnailUrl String?
  // Where the lesson media comes from: UPLOAD (bucket), LINK (external), MEDIA (library pick).
  source       LessonSource @default(UPLOAD)
  durationSec Int?
  isPreview  Boolean    @default(false)
  // Draft vs Published. Draft lessons are hidden from learners.
  isPublished Boolean   @default(true)

  // Optional grouping into a CourseModule (section). Null = ungrouped (legacy).
  moduleId   String?
  // Per-lesson unlock rule. SINGLE = unlock as soon as the previous lesson is
  // completed; BOTH = previous lesson completed AND the time delay elapsed.
  lockMode         ModuleLockMode @default(SINGLE)
  // Hours to wait after the previous lesson is completed before this one opens.
  // Only enforced when lockMode = BOTH.
  unlockDelayHours Int            @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  quiz   Quiz?
  completions LessonCompletion[]
  notes       LessonNote[]
  questions   LessonQuestion[]

  @@unique([courseId, index])
}

model Enrollment {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  percentComplete Float    @default(0)
  lessonsComplete Int      @default(0)
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  // Access window. null = lifetime access. When `accessUntil` is in the past
  // (or `revokedAt` is set) the learner loses access and the mobile app wipes
  // any downloaded videos for this course.
  accessUntil     DateTime?
  revokedAt       DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum QuizQuestionType {
  SINGLE
  MULTI
  TRUE_FALSE
}

model Quiz {
  id       String @id @default(cuid())
  courseId String
  lessonId String? @unique
  title    String
  passScore Int    @default(70)
  // Optional countdown for the whole quiz, in seconds (null = no timer).
  timeLimitSec Int?
  // Allowed attempts (0 = unlimited).
  maxAttempts  Int @default(0)
  // Randomize question + option order per attempt.
  shuffle      Boolean @default(false)

  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?        @relation(fields: [lessonId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id      String @id @default(cuid())
  quizId  String
  index   Int
  prompt  String
  type    QuizQuestionType @default(SINGLE)
  // Marks awarded for this question (weighted scoring).
  points  Int @default(1)
  // Optional explanation shown in review mode.
  explanation String?
  // JSON-encoded options + correct answer index.
  options String
  // Correct option index for SINGLE / TRUE_FALSE.
  answer  Int
  // JSON-encoded array of correct option indices for MULTI questions.
  correct String?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, index])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int      @default(0)
  passed    Boolean  @default(false)
  // JSON-encoded array of selected option indices, one per question (review).
  answers   String?
  // How long the learner took, in seconds.
  timeTakenSec Int?
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model LessonCompletion {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  courseId  String
  progress  Float    @default(1)
  // Last playback position in seconds, so a video lesson can resume where the
  // learner left off (independent of completion progress).
  positionSec Int?
  // Timestamp the lesson first reached full completion (progress >= 1). Drives
  // time-gated ("drip") unlocking of the next lesson / module.
  completedAt DateTime?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Assignment {
  id          String   @id @default(cuid())
  courseId    String
  // Optional 1:1 link to an ASSIGNMENT-type lesson. The assignment task, its
  // reference attachments and the submission flow all hang off this lesson.
  lessonId    String?  @unique
  title       String
  // Rich task description / instructions (markdown). Shown on the Details tab.
  description String?
  // JSON-encoded array of instructor reference files: [{ key, name, size }].
  // Shown on the Attachments tab of the assignment.
  attachments String?
  // Optional cover image (URL or storage key). Recommended 1280x720.
  thumbnailUrl String?
  // Graded assignments get a score; ungraded ones are completion-only.
  graded      Boolean  @default(true)
  // Rich-text message shown to learners after they complete the assignment.
  completionMessage String?
  dueAt       DateTime?

  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  userId       String
  // The learner's typed answer ("Your answer" textarea).
  answerText   String?
  // JSON-encoded array of submitted files: [{ key, name, size }].
  attachments  String?
  // Legacy single-file key (kept for backward compatibility).
  contentKey   String?
  status       SubmissionStatus @default(UNDER_REVIEW)
  grade        Int?
  feedback     String?
  submittedAt  DateTime @default(now())
  reviewedAt   DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
}

model Certificate {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  serial    String   @unique
  issuedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

// A learner's star rating + optional written review of a course. One review per
// learner per course (upsert on change).
model CourseReview {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
}

// A private personal note a learner takes on a lesson, optionally anchored to a
// video timestamp. Visible only to its author.
model LessonNote {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  courseId    String
  body        String
  positionSec Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// A public question asked on a lesson (course Q&A). Instructors/admins or peers
// answer; the author or an admin can mark it resolved.
model LessonQuestion {
  id        String   @id @default(cuid())
  lessonId  String
  courseId  String
  userId    String
  body      String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson  Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])
  answers LessonAnswer[]
}

model LessonAnswer {
  id           String   @id @default(cuid())
  questionId   String
  userId       String
  body         String
  // True when the responder is an instructor/admin (badge in the UI).
  isInstructor Boolean  @default(false)
  createdAt    DateTime @default(now())

  question LessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id])
}

// ---- Gamification (Phase 10): points, streaks, badges ----
// Per-user game stats. `points` is cached (derived from learning activity in
// GamificationService) so the leaderboard is a single cheap query; streaks are
// maintained via daily check-ins from the apps.
model UserGameStat {
  id            String   @id @default(cuid())
  userId        String   @unique
  points        Int      @default(0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  // Last active calendar day as a YYYY-MM-DD string in the learner's local tz.
  lastActiveDay String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([points])
}

// A badge earned by a user. Badge definitions (name/description/icon/criteria)
// live in code (GamificationService.BADGES); only earned rows are stored here.
model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
}


// A logged-in device/session for a user. Used to enforce the concurrent device
// limit and to let users (and admins) see + sign out devices remotely.
model UserDevice {
  id         String    @id @default(cuid())
  userId     String
  // Stable client-generated id (stored on the device). Identifies the
  // physical device across logins so re-login on the same phone reuses the row.
  deviceId   String
  label      String?
  platform   String?
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  // When set, the device has been signed out remotely / kicked by the limit.
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}


// ===========================================================================
// Course monetization, engagement & live features
// ===========================================================================

// A purchasable ACCESS OFFER (pricing tier) for one course. The same course can
// be sold at several different prices, each with its own name and access
// window, e.g. "1 Month - 1500", "Lifetime - 5000". Buying an offer grants the
// learner enrollment access for accessDurationDays (null = lifetime).
model CourseOffer {
  id                 String   @id @default(cuid())
  courseId           String
  name               String
  description        String?
  price              Float    @default(0)
  currency           String   @default("PKR")
  // null = lifetime access; otherwise overrides the course default duration.
  accessDurationDays Int?
  isActive           Boolean  @default(true)
  index              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// A GLOBAL discount coupon. Works across every checkout (course, book, bundle,
// plan, community). discountType = PERCENT (amount = 0-100) or FIXED (amount =
// currency units).
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String    @default("PERCENT")
  amount         Float     @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  maxRedemptions Int?
  timesRedeemed  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// A learner comment / discussion entry at the course level (optionally pinned
// to a lesson). parentId enables one level of threaded replies.
model CourseComment {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  lessonId  String?
  body      String
  parentId  String?
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// A badge awarded for a course. type = WELCOME (on enrollment) or COMPLETION
// (on finishing the course).
model CourseBadge {
  id        String   @id @default(cuid())
  courseId  String
  type      String   @default("WELCOME")
  name      String
  imageUrl  String?
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// A scheduled live class/webinar for a course. status = SCHEDULED | LIVE |
// ENDED | CANCELLED. joinUrl is the meeting link (Zoom/Meet/etc.).
model LiveSession {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  scheduledAt DateTime
  durationMin Int      @default(60)
  joinUrl     String?
  status      String   @default("SCHEDULED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}
