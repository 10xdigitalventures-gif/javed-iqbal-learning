# ============================================================
# Prof. Dr. Javed Iqbal Learning App — root .gitignore
# ============================================================

# Dependencies
node_modules/

# Environment variables — NEVER commit secrets
.env
.env.local
.env.production
.env*.local

# Build outputs
dist/
build/
.next/
out/

# Expo / React Native
.expo/
web-build/
mobile/android/
mobile/ios/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Uploads (user-uploaded files, store in S3/cloud in production)
uploads/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo

# Prisma — keep schema & migrations, ignore generated client binary
backend/node_modules/

# Jest / test coverage
coverage/

# EAS Build
.easignore
